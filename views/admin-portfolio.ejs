<%- include('partials/head', { title: t.page_portfolio }) %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <h1 class="page-title"><%= t.page_portfolio %></h1>
    <form method="POST" action="/admin/fetch-prices" id="fetchForm">
      <button type="submit" class="btn btn-primary" id="fetchBtn">
        <%= t.btn_fetch %>
      </button>
    </form>
  </div>

  <% if (flash.error) { %><div class="alert alert-error"><%= flash.error %></div><% } %>
  <% if (flash.success) { %><div class="alert alert-success"><%= flash.success %></div><% } %>

  <!-- Price Table -->
  <div class="card">
    <div class="section-header">
      <div class="section-title"><%= t.market_prices_title %></div>
      <span class="dim small"><%= t.market_prices_sub %></span>
    </div>

    <% if (tickers.length === 0) { %>
      <div class="empty-state"><%= t.no_holdings_admin %></div>
    <% } else { %>

    <form method="POST" action="/admin/prices" id="manualPriceForm">
      <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t.col_ticker %></th>
            <th class="num"><%= t.col_avg_cost %></th>
            <th class="num"><%= t.col_market_k %></th>
            <th class="num"><%= t.col_change %></th>
            <th class="num"><%= t.col_updated %></th>
            <th class="num"><%= t.col_manual %></th>
          </tr>
        </thead>
        <tbody>
          <% tickers.forEach(t_ => { %>
          <%
            const chg = t_.market_price
              ? ((t_.market_price - t_.avg_cost_all) / t_.avg_cost_all * 100).toFixed(2)
              : null;
          %>
          <tr>
            <td><span class="ticker"><%= t_.ticker %></span>
              <span class="dim small"> · <%= t_.holder_count %> <%= t.col_holders %></span>
            </td>
            <td class="num dim"><%= (t_.avg_cost_all / 1000).toFixed(2) %></td>
            <td class="num">
              <% if (t_.market_price) { %>
                <span class="bold <%= chg >= 0 ? 'text-buy' : 'text-sell' %>">
                  <%= (t_.market_price / 1000).toFixed(2) %>
                </span>
              <% } else { %>
                <span class="dim">—</span>
              <% } %>
            </td>
            <td class="num">
              <% if (chg !== null) { %>
                <span class="<%= parseFloat(chg) >= 0 ? 'text-buy' : 'text-sell' %>">
                  <%= parseFloat(chg) >= 0 ? '+' : '' %><%= chg %>%
                </span>
              <% } else { %><span class="dim">—</span><% } %>
            </td>
            <td class="num dim small"><%= t_.price_updated_at ? formatDate(t_.price_updated_at) : '—' %></td>
            <td class="num">
              <input
                type="number"
                name="prices[<%= t_.ticker %>]"
                step="0.01" min="0.01"
                placeholder="<%= t_.market_price ? (t_.market_price / 1000).toFixed(2) : '...' %>"
                class="price-input"
              >
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
      <div style="margin-top:14px">
        <button type="submit" class="btn" style="border-color:var(--border2);color:var(--text-dim)">
          <%= t.btn_save_manual %>
        </button>
      </div>
    </form>
    <% } %>
  </div>

  <!-- Per-User Portfolio -->
  <%
    const byUser = {};
    portfolios.forEach(row => {
      const key = row.user_id;
      if (!byUser[key]) byUser[key] = {
        username: row.username,
        display_name: row.display_name,
        balance: row.balance,
        holdings: []
      };
      byUser[key].holdings.push(row);
    });
    const STARTING = 1000000000;
  %>

  <% Object.values(byUser).forEach(u => { %>
  <%
    let costTotal = 0, marketTotal = 0, allPriced = true;
    u.holdings.forEach(h => {
      costTotal   += h.cost_basis;
      if (h.market_price) marketTotal += h.market_price * h.total_quantity;
      else { allPriced = false; marketTotal += h.cost_basis; }
    });
    const portfolioVal = allPriced ? marketTotal : costTotal;
    const totalAssets  = u.balance + portfolioVal;
    const unrealPnl    = allPriced ? marketTotal - costTotal : null;
    const totalPnl     = totalAssets - STARTING;
  %>
  <div class="card user-portfolio-card">
    <div class="user-portfolio-header">
      <div>
        <div class="bold" style="font-size:15px"><%= u.display_name || u.username %></div>
        <div class="dim small"><%= t.cash_label %>: ₫<%= formatVND(u.balance) %></div>
      </div>
      <div style="text-align:right">
        <div class="bold" style="font-size:15px">₫<%= formatVND(totalAssets) %> <%= t.total_assets_label %></div>
        <div class="small <%= totalPnl >= 0 ? 'text-buy' : 'text-sell' %>">
          P&L: <%= totalPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(totalPnl)) %>
          &nbsp;(<%= (totalPnl / STARTING * 100).toFixed(2) %>%)
        </div>
        <% if (unrealPnl !== null) { %>
        <div class="tiny-dim <%= unrealPnl >= 0 ? 'text-buy' : 'text-sell' %>">
          <%= unrealPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(unrealPnl)) %> <%= t.unrealized_label %>
        </div>
        <% } %>
      </div>
    </div>

    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t.col_ticker %></th>
          <th class="num"><%= t.col_qty %></th>
          <th class="num"><%= t.col_locked_qty %></th>
          <th class="num"><%= t.col_avg_cost %></th>
          <th class="num"><%= t.col_market %></th>
          <th class="num"><%= t.col_cost_basis %></th>
          <th class="num"><%= t.col_market_val %></th>
          <th class="num"><%= t.col_pnl %></th>
          <th class="num">%</th>
        </tr>
      </thead>
      <tbody>
        <% u.holdings.forEach(h => { %>
        <%
          const mv   = h.market_price ? h.market_price * h.total_quantity : null;
          const pnl  = mv !== null ? mv - h.cost_basis : null;
          const pct  = pnl !== null ? (pnl / h.cost_basis * 100).toFixed(2) : null;
        %>
        <tr>
          <td><span class="ticker"><%= h.ticker %></span></td>
          <td class="num"><%= h.total_quantity.toLocaleString('vi-VN') %></td>
          <td class="num">
            <%= h.available_quantity.toLocaleString('vi-VN') %>
            <% if (h.locked_quantity > 0) { %>
              <span class="dim"> +<%= h.locked_quantity.toLocaleString('vi-VN') %></span>
            <% } %>
          </td>
          <td class="num dim"><%= (h.avg_cost / 1000).toFixed(2) %></td>
          <td class="num">
            <% if (h.market_price) { %>
              <span class="bold <%= pnl >= 0 ? 'text-buy' : 'text-sell' %>"><%= (h.market_price / 1000).toFixed(2) %></span>
            <% } else { %><span class="dim">—</span><% } %>
          </td>
          <td class="num dim">₫<%= formatVND(h.cost_basis) %></td>
          <td class="num">
            <% if (mv !== null) { %>₫<%= formatVND(mv) %><% } else { %><span class="dim">—</span><% } %>
          </td>
          <td class="num <%= pnl !== null ? (pnl >= 0 ? 'text-buy' : 'text-sell') : '' %>">
            <% if (pnl !== null) { %><%= pnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnl)) %>
            <% } else { %><span class="dim">—</span><% } %>
          </td>
          <td class="num <%= pct !== null ? (parseFloat(pct) >= 0 ? 'text-buy' : 'text-sell') : '' %>">
            <% if (pct !== null) { %><%= pnl >= 0 ? '+' : '' %><%= pct %>%<% } else { %><span class="dim">—</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
  <% }) %>

  <% if (Object.keys(byUser).length === 0) { %>
    <div class="empty-state"><%= t.no_portfolios %></div>
  <% } %>

</div>

<script>
  document.getElementById('fetchForm').addEventListener('submit', function() {
    const btn = document.getElementById('fetchBtn');
    btn.textContent = '<%= t.btn_fetching %>';
    btn.disabled = true;
  });
</script>

<%- include('partials/foot') %>
