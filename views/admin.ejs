<%- include('partials/head', { title: t.page_admin }) %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <h1 class="page-title"><%= t.page_admin %></h1>
    <span class="dim"><%= t.admin_subtitle %></span>
  </div>

  <% if (flash.error) { %><div class="alert alert-error"><%= flash.error %></div><% } %>
  <% if (flash.success) { %><div class="alert alert-success"><%= flash.success %></div><% } %>

  <!-- Pending Orders -->
  <div class="card">
    <div class="section-header">
      <div class="section-title"><%= t.pending_title %></div>
      <span class="badge <%= pendingOrders.length > 0 ? 'badge-pending' : 'badge-approved' %>">
        <%= pendingOrders.length %> <%= t.orders_suffix %>
      </span>
    </div>

    <% if (pendingOrders.length === 0) { %>
      <div class="empty-state"><%= t.no_pending %></div>
    <% } else { %>
    <div class="pending-list">
      <% pendingOrders.forEach(o => { %>
      <div class="pending-card">
        <div class="pending-header">
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <span class="dim small">#<%= o.id %></span>
            <span class="badge-type badge-<%= o.order_type %> big"><%= o.order_type === 'buy' ? t.type_buy : t.type_sell %></span>
            <span class="ticker big"><%= o.ticker %></span>
            <span class="bold">@</span>
            <span><%= (o.price / 1000).toFixed(2) %></span>
          </div>
          <div class="dim small"><%= formatDate(o.created_at) %></div>
        </div>

        <div class="pending-details">
          <div class="detail-item">
            <span class="dim"><%= t.label_user %></span>
            <span class="bold"><%= o.username %></span>
          </div>
          <div class="detail-item">
            <span class="dim"><%= t.label_qty_detail %></span>
            <span><%= o.quantity.toLocaleString('vi-VN') %></span>
          </div>
          <div class="detail-item">
            <span class="dim"><%= t.label_trade_val %></span>
            <span>₫<%= formatVND(o.total_value) %></span>
          </div>
          <div class="detail-item">
            <span class="dim"><%= t.label_fee %></span>
            <span>₫<%= formatVND(o.fee) %></span>
          </div>
          <div class="detail-item">
            <span class="dim"><%= o.order_type === 'buy' ? t.label_total_buy : t.label_total_sell %></span>
            <span class="bold">
              <% if (o.order_type === 'buy') { %>
                <span class="text-sell">₫<%= formatVND(o.total_value + o.fee) %></span>
              <% } else { %>
                <span class="text-buy">₫<%= formatVND(o.total_value - o.fee) %></span>
              <% } %>
            </span>
          </div>
        </div>

        <div class="pending-actions">
          <form method="POST" action="/admin/orders/<%= o.id %>/approve" class="action-form">
            <input type="text" name="note" placeholder="<%= t.note_ph_approve %>" class="note-input">
            <button type="submit" class="btn btn-approve"><%= t.btn_approve %></button>
          </form>
          <form method="POST" action="/admin/orders/<%= o.id %>/reject" class="action-form">
            <input type="text" name="note" placeholder="<%= t.note_ph_reject %>" class="note-input">
            <button type="submit" class="btn btn-reject"><%= t.btn_reject %></button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Users Overview -->
  <div class="card">
    <div class="section-title" style="margin-bottom:16px"><%= t.users_title %> (<%= users.length %>)</div>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t.col_player %></th>
          <th class="num"><%= t.col_balance %></th>
          <th class="num"><%= t.col_market_val %></th>
          <th class="num"><%= t.col_total %></th>
          <th class="num"><%= t.col_pnl %></th>
          <th class="num"><%= t.col_pending_buy %></th>
        </tr>
      </thead>
      <tbody>
        <% const STARTING = 1000000000; %>
        <% users.forEach(u => { %>
        <%
          const totalAssets = u.balance + u.holdings_value;
          const unrealPnl   = u.holdings_value - u.holdings_cost;
          const totalPnl    = totalAssets - STARTING;
        %>
        <tr>
          <td>
            <strong><%= u.display_name || u.username %></strong>
            <span class="dim small"> · #<%= u.id %></span>
          </td>
          <td class="num">₫<%= formatVND(u.balance) %></td>
          <td class="num">
            ₫<%= formatVND(u.holdings_value) %>
            <% if (unrealPnl !== 0) { %>
              <div class="tiny-dim <%= unrealPnl >= 0 ? 'text-buy' : 'text-sell' %>">
                <%= unrealPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(unrealPnl)) %>
              </div>
            <% } %>
          </td>
          <td class="num"><strong>₫<%= formatVND(totalAssets) %></strong></td>
          <td class="num">
            <span class="<%= totalPnl >= 0 ? 'text-buy' : 'text-sell' %>">
              <%= totalPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(totalPnl)) %>
            </span>
            <div class="tiny-dim <%= totalPnl >= 0 ? 'text-buy' : 'text-sell' %>">
              <%= (totalPnl / STARTING * 100).toFixed(2) %>%
            </div>
          </td>
          <td class="num">
            <% if (u.pending_buy_cost > 0) { %>
              <span class="text-pending">₫<%= formatVND(u.pending_buy_cost) %></span>
            <% } else { %><span class="dim">—</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>

  <!-- All Orders -->
  <div class="card">
    <div class="section-title" style="margin-bottom:16px"><%= t.all_orders_title %></div>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th><%= t.col_user %></th>
          <th><%= t.col_type %></th>
          <th><%= t.col_ticker %></th>
          <th class="num"><%= t.col_qty_short %></th>
          <th class="num"><%= t.col_price %></th>
          <th class="num"><%= t.col_value %></th>
          <th><%= t.col_status %></th>
          <th><%= t.col_time %></th>
          <th><%= t.col_note %></th>
        </tr>
      </thead>
      <tbody>
        <% allOrders.forEach(o => { %>
        <tr class="<%= o.status === 'rejected' ? 'row-rejected' : '' %>">
          <td class="dim">#<%= o.id %></td>
          <td><%= o.username %></td>
          <td><span class="badge-type badge-<%= o.order_type %>"><%= o.order_type === 'buy' ? t.type_buy : t.type_sell %></span></td>
          <td><span class="ticker"><%= o.ticker %></span></td>
          <td class="num"><%= o.quantity.toLocaleString('vi-VN') %></td>
          <td class="num"><%= (o.price / 1000).toFixed(2) %></td>
          <td class="num">₫<%= formatVND(o.total_value) %></td>
          <td><span class="badge badge-<%= o.status %>"><%= o.status === 'pending' ? t.status_pending : o.status === 'approved' ? t.status_approved : t.status_rejected %></span></td>
          <td class="dim small"><%= formatDate(o.created_at) %></td>
          <td class="dim small"><%= o.admin_note || '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>

</div>

<%- include('partials/foot') %>
