<%- include('partials/head', { title: t.page_new_order }) %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <h1 class="page-title"><%= t.page_new_order %></h1>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="two-col">
    <div class="card">
      <form method="POST" action="/orders" id="orderForm">

        <div class="form-group">
          <label><%= t.label_order_type %></label>
          <div class="toggle-group">
            <label class="toggle-option">
              <input type="radio" name="order_type" value="buy" id="typeBuy" <%= prefill.type === 'buy' ? 'checked' : '' %>>
              <span class="toggle-label toggle-buy"><%= t.type_buy %></span>
            </label>
            <label class="toggle-option">
              <input type="radio" name="order_type" value="sell" id="typeSell" <%= prefill.type === 'sell' ? 'checked' : '' %>>
              <span class="toggle-label toggle-sell"><%= t.type_sell %></span>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label><%= t.label_ticker %></label>
          <input type="text" name="ticker" id="ticker" value="<%= prefill.ticker %>"
            placeholder="<%= t.placeholder_ticker %>" required maxlength="10"
            style="text-transform:uppercase">
        </div>

        <div id="holdingInfo" class="holding-info" style="display:none">
          <div class="holding-info-row">
            <span class="dim"><%= t.label_holding_cost %></span>
            <span id="holdingCost" class="bold">—</span>
          </div>
          <div class="holding-info-row">
            <span class="dim"><%= t.label_holding_avail %></span>
            <span id="holdingQty">—</span>
          </div>
        </div>

        <div class="form-group">
          <label><%= t.label_qty %></label>
          <input type="number" name="quantity" id="quantity" min="100" step="100" placeholder="100" required>
        </div>

        <div class="form-group">
          <label><%= t.label_price %></label>
          <input type="number" name="price" id="price" min="0.01" step="0.01" placeholder="28.4" required>
        </div>

        <div class="order-summary" id="orderSummary" style="display:none">
          <div class="summary-row">
            <span><%= t.sum_trade_val %></span>
            <span id="sumTotal">—</span>
          </div>
          <div class="summary-row">
            <span id="pnlRow" style="display:none"><%= t.sum_est_pnl %></span>
            <span id="sumPnl" style="display:none">—</span>
          </div>
          <div class="summary-row">
            <span><%= t.sum_fee %></span>
            <span id="sumFee">—</span>
          </div>
          <div class="summary-row summary-divider">
            <span id="sumNetLabel"><%= t.sum_pay %></span>
            <span id="sumNet" class="bold">—</span>
          </div>
        </div>

        <div id="balanceCheck" class="small dim" style="margin-top:8px;"></div>

        <button type="submit" class="btn btn-primary btn-full" style="margin-top:20px"><%= t.btn_submit %></button>
      </form>
    </div>

    <div>
      <div class="card">
        <div class="section-title" style="margin-bottom:12px"><%= t.sidebar_balance %></div>
        <div class="big-number">₫<%= formatVND(availableBalance) %></div>
      </div>

      <% if (holdings.length > 0) { %>
      <div class="card">
        <div class="section-title" style="margin-bottom:12px"><%= t.sidebar_sellable %></div>
        <table>
          <thead>
            <tr>
              <th><%= t.col_ticker %></th>
              <th class="num"><%= t.col_cost_short %></th>
              <th class="num"><%= t.col_avail_short %></th>
            </tr>
          </thead>
          <tbody>
            <% holdings.forEach(h => { %>
            <% if (h.available_quantity > 0) { %>
            <tr>
              <td>
                <a href="/orders/new?ticker=<%= h.ticker %>&type=sell" style="color:inherit">
                  <span class="ticker"><%= h.ticker %></span>
                </a>
              </td>
              <td class="num dim"><%= (h.avg_cost / 1000).toFixed(2) %></td>
              <td class="num"><%= h.available_quantity.toLocaleString('vi-VN') %></td>
            </tr>
            <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  const availBal = <%= availableBalance %>;
  const sumPayLabel    = '<%= t.sum_pay %>';
  const sumReceiveLabel = '<%= t.sum_receive %>';
  const balOkPrefix  = '<%= t.js_balance_ok %>';
  const balLowPrefix = '<%= t.js_balance_low %>';

  const holdingsMap = {};
  <% holdings.forEach(h => { %>
  holdingsMap['<%= h.ticker %>'] = { avgCost: <%= h.avg_cost %>, availableQty: <%= h.available_quantity %> };
  <% }) %>

  function fmt(n) {
    return '₫' + Math.round(n).toLocaleString('vi-VN');
  }

  function updateHoldingInfo() {
    const ticker = document.getElementById('ticker').value.toUpperCase();
    const isSell = document.getElementById('typeSell').checked;
    const info = holdingsMap[ticker];
    const box = document.getElementById('holdingInfo');
    if (isSell && info) {
      document.getElementById('holdingCost').textContent = (info.avgCost / 1000).toFixed(2);
      document.getElementById('holdingQty').textContent = info.availableQty.toLocaleString('vi-VN');
      box.style.display = 'flex';
    } else {
      box.style.display = 'none';
    }
  }

  function calc() {
    const qty    = parseInt(document.getElementById('quantity').value) || 0;
    const prcK   = parseFloat(document.getElementById('price').value) || 0;
    const prc    = prcK * 1000;
    const isBuy  = document.getElementById('typeBuy').checked;
    const ticker = document.getElementById('ticker').value.toUpperCase();

    if (qty > 0 && prc > 0) {
      const total = qty * prc;
      const fee   = total * 0.001;
      const net   = isBuy ? total + fee : total - fee;

      document.getElementById('sumTotal').textContent = fmt(total);
      document.getElementById('sumFee').textContent   = fmt(fee);
      document.getElementById('sumNet').textContent   = fmt(net);
      document.getElementById('sumNetLabel').textContent = isBuy ? sumPayLabel : sumReceiveLabel;
      document.getElementById('orderSummary').style.display = 'block';

      const pnlRow = document.getElementById('pnlRow');
      const sumPnl = document.getElementById('sumPnl');
      if (!isBuy && holdingsMap[ticker]) {
        const costBasis = holdingsMap[ticker].avgCost * qty;
        const pnl = net - costBasis;
        const pnlPct = (pnl / costBasis * 100).toFixed(2);
        pnlRow.style.display = '';
        sumPnl.style.display = '';
        sumPnl.textContent = (pnl >= 0 ? '+' : '') + fmt(pnl) + ' (' + (pnl >= 0 ? '+' : '') + pnlPct + '%)';
        sumPnl.style.color = pnl >= 0 ? 'var(--green)' : 'var(--red)';
      } else {
        pnlRow.style.display = 'none';
        sumPnl.style.display = 'none';
      }

      if (isBuy) {
        const check = document.getElementById('balanceCheck');
        if (net > availBal) {
          check.textContent = balLowPrefix + fmt(net - availBal);
          check.style.color = 'var(--red)';
        } else {
          check.textContent = balOkPrefix + fmt(availBal - net);
          check.style.color = 'var(--text-dim)';
        }
      } else {
        document.getElementById('balanceCheck').textContent = '';
      }
    } else {
      document.getElementById('orderSummary').style.display = 'none';
      document.getElementById('balanceCheck').textContent = '';
    }
  }

  document.getElementById('quantity').addEventListener('input', calc);
  document.getElementById('price').addEventListener('input', calc);
  document.getElementById('typeBuy').addEventListener('change', function() { updateHoldingInfo(); calc(); });
  document.getElementById('typeSell').addEventListener('change', function() { updateHoldingInfo(); calc(); });
  document.getElementById('ticker').addEventListener('input', function() {
    this.value = this.value.toUpperCase();
    updateHoldingInfo();
    calc();
  });

  updateHoldingInfo();
  calc();
</script>

<%- include('partials/foot') %>
