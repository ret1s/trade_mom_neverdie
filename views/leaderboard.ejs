<%- include('partials/head', { title: t.page_leaderboard }) %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <h1 class="page-title">
      <% if (tournament) { %><%= t.page_leaderboard_full(tournament.name) %><% } else { %><%= t.page_leaderboard %><% } %>
    </h1>
  </div>

  <% if (!tournament) { %>
    <div class="card"><div class="empty-state"><%= t.no_tournament %></div></div>
  <% } else if (users.length === 0) { %>
    <div class="card"><div class="empty-state"><%= t.no_players %></div></div>
  <% } else { %>
  <div class="card">
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t.col_rank %></th>
          <th><%= t.col_player %></th>
          <th class="num"><%= t.col_balance %></th>
          <th class="num"><%= t.col_stock_val %></th>
          <th class="num"><%= t.col_total %></th>
          <th class="num"><%= t.col_pnl_vs_start %></th>
          <th><%= t.col_joined %></th>
        </tr>
      </thead>
      <tbody>
        <% const STARTING = 1000000000; %>
        <% users.forEach((u, i) => { %>
        <%
          const totalAssets = u.balance + u.holdings_value;
          const pnl = totalAssets - STARTING;
          const pnlPct = (pnl / STARTING * 100).toFixed(2);
        %>
        <tr class="<%= i === 0 ? 'row-top' : '' %>">
          <td>
            <% if (i === 0) { %>
              <span class="rank-1">#1</span>
            <% } else if (i === 1) { %>
              <span class="rank-2">#2</span>
            <% } else if (i === 2) { %>
              <span class="rank-3">#3</span>
            <% } else { %>
              <span class="dim">#<%= i + 1 %></span>
            <% } %>
          </td>
          <td>
            <a href="/player/<%= u.username %>" style="color:inherit;text-decoration:none">
              <strong><%= u.display_name || u.username %></strong>
            </a>
          </td>
          <td class="num">₫<%= formatVND(u.balance) %></td>
          <td class="num">₫<%= formatVND(u.holdings_value) %></td>
          <td class="num"><strong>₫<%= formatVND(totalAssets) %></strong></td>
          <td class="num">
            <span class="<%= pnl >= 0 ? 'text-buy' : 'text-sell' %>">
              <%= pnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnl)) %>
              (<%= pnl >= 0 ? '+' : '' %><%= pnlPct %>%)
            </span>
          </td>
          <td class="dim small"><%= formatDate(u.created_at) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
  <% } %>
</div>

<%- include('partials/foot') %>
