<%- include('partials/head', { title: market === 'derivative' ? t.page_derivative : t.page_dashboard }) %>
<%- include('partials/nav') %>

<div class="container">

  <% if (flash.error) { %><div class="alert alert-error"><%= flash.error %></div><% } %>
  <% if (flash.success) { %><div class="alert alert-success"><%= flash.success %></div><% } %>

  <div class="page-header">
    <h1 class="page-title"><%= market === 'derivative' ? t.page_derivative : t.page_dashboard %></h1>
    <div style="display:flex;gap:8px;align-items:center">
      <% if (dnseStatus) { %>
        <span class="dim small" style="margin-right:4px" title="<%= dnseStatus.tradingHours ? t.dnse_trading_hours : t.dnse_off_hours %>">
          <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= dnseStatus.connected ? 'var(--green)' : 'var(--text-dim)' %>;margin-right:4px"></span>DNSE
        </span>
      <% } %>
      <form method="POST" action="/nav/record">
        <input type="hidden" name="note" value="">
        <input type="hidden" name="market" value="<%= market %>">
        <button type="submit" class="btn" style="border-color:var(--border2);color:var(--text-dim)"><%= t.btn_record_nav %></button>
      </form>
      <a href="/orders/new?market=<%= market %>" class="btn btn-primary"><%= t.btn_new_order %></a>
    </div>
  </div>

  <%
    const isDerivative = market === 'derivative';
    const userBalance = isDerivative ? user.derivative_balance : user.balance;
    let marketHoldingsValue = 0;
    let hasMarketPrices = false;
    holdings.forEach(h => {
      if (h.market_price) {
        marketHoldingsValue += h.market_price * h.total_quantity;
        hasMarketPrices = true;
      } else {
        marketHoldingsValue += h.avg_cost * h.total_quantity;
      }
    });
    const unrealizedPnl = hasMarketPrices ? marketHoldingsValue - holdingsValue : null;
    const totalAssets = availableBalance + marketHoldingsValue;
  %>
  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-label"><%= isDerivative ? t.stat_deriv_balance : t.stat_avail_balance %></div>
      <div class="stat-value">₫<%= formatVND(availableBalance) %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label"><%= t.stat_portfolio %></div>
      <div class="stat-value">₫<%= formatVND(marketHoldingsValue) %></div>
      <% if (unrealizedPnl !== null) { %>
        <div class="stat-note <%= unrealizedPnl >= 0 ? 'text-buy' : 'text-sell' %>">
          <%= unrealizedPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(unrealizedPnl)) %> <%= t.stat_unrealized %>
        </div>
      <% } %>
    </div>
    <div class="stat-card">
      <div class="stat-label"><%= t.stat_total_assets %></div>
      <div class="stat-value highlight">₫<%= formatVND(totalAssets) %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label"><%= t.stat_pnl %></div>
      <% const pnlVsStart = totalAssets - startingBalance; %>
      <div class="stat-value <%= pnlVsStart >= 0 ? 'text-buy' : 'text-sell' %>">
        <%= pnlVsStart >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnlVsStart)) %>
      </div>
      <div class="stat-note <%= pnlVsStart >= 0 ? 'text-buy' : 'text-sell' %>">
        <%= (pnlVsStart / startingBalance * 100).toFixed(2) %>%
      </div>
    </div>
  </div>

  <div class="card">
    <div class="section-header">
      <div class="section-title"><%= isDerivative ? t.deriv_holdings_title : t.holdings_title %></div>
      <span class="dim"><%= holdings.length %></span>
    </div>
    <% if (holdings.length === 0) { %>
      <div class="empty-state"><%= isDerivative ? t.deriv_no_holdings : t.no_holdings %> <a href="/orders/new?market=<%= market %>"><%= isDerivative ? t.deriv_no_holdings_link : t.no_holdings_link %></a></div>
    <% } else { %>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t.col_ticker %></th>
          <th class="num"><%= t.col_qty %></th>
          <th class="num"><%= t.col_available %></th>
          <th class="num"><%= t.col_cost %></th>
          <th class="num"><%= t.col_market %></th>
          <th class="num"><%= t.col_invested %></th>
          <th class="num"><%= t.col_market_val %></th>
          <th class="num"><%= t.col_pnl %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% holdings.forEach(h => { %>
        <%
          const marketVal = h.market_price ? h.market_price * h.total_quantity : null;
          const costBasis = h.avg_cost * h.total_quantity;
          const pnl = marketVal !== null ? marketVal - costBasis : null;
          const pnlPct = pnl !== null ? (pnl / costBasis * 100).toFixed(2) : null;
        %>
        <tr>
          <td><span class="ticker"><%= h.ticker %></span></td>
          <td class="num"><%= h.total_quantity.toLocaleString('vi-VN') %></td>
          <td class="num">
            <%= h.available_quantity.toLocaleString('vi-VN') %>
            <% if (h.locked_quantity > 0) { %>
              <div class="tiny-dim">+<%= h.locked_quantity.toLocaleString('vi-VN') %>
                <% if (h.next_settlement) { %>(<%= h.next_settlement %>)<% } %>
              </div>
            <% } %>
          </td>
          <td class="num"><%= (h.avg_cost / 1000).toFixed(2) %></td>
          <td class="num">
            <% if (h.market_price) { %>
              <span class="bold <%= pnl >= 0 ? 'text-buy' : 'text-sell' %>"><%= (h.market_price / 1000).toFixed(2) %></span>
            <% } else { %>
              <span class="dim">—</span>
            <% } %>
          </td>
          <td class="num dim">₫<%= formatVND(costBasis) %></td>
          <td class="num">
            <% if (marketVal !== null) { %>₫<%= formatVND(marketVal) %><% } else { %><span class="dim">—</span><% } %>
          </td>
          <td class="num">
            <% if (pnl !== null) { %>
              <div class="<%= pnl >= 0 ? 'text-buy' : 'text-sell' %>">
                <%= pnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnl)) %>
              </div>
              <div class="tiny-dim <%= pnl >= 0 ? 'text-buy' : 'text-sell' %>">
                <%= pnl >= 0 ? '+' : '' %><%= pnlPct %>%
              </div>
            <% } else { %>
              <span class="dim">—</span>
            <% } %>
          </td>
          <td>
            <% if (h.available_quantity > 0) { %>
            <a href="/orders/new?ticker=<%= h.ticker %>&type=sell&market=<%= market %>" class="btn btn-sm btn-sell"><%= t.btn_sell %></a>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>

  <div class="card">
    <div class="section-header">
      <div class="section-title"><%= t.recent_orders %></div>
      <a href="/orders?market=<%= market %>" class="dim small-link"><%= t.view_all %></a>
    </div>
    <% if (recentOrders.length === 0) { %>
      <div class="empty-state"><%= t.no_orders %></div>
    <% } else { %>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th><%= t.col_type %></th>
          <th><%= t.col_ticker %></th>
          <th class="num"><%= t.col_qty_short %></th>
          <th class="num"><%= t.col_price %></th>
          <th class="num"><%= t.col_value %></th>
          <th><%= t.col_status %></th>
          <th><%= t.col_time %></th>
        </tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(o => { %>
        <tr>
          <td class="dim">#<%= o.id %></td>
          <td><span class="badge-type badge-<%= o.order_type %>"><%= o.order_type === 'buy' ? t.type_buy : t.type_sell %></span></td>
          <td><span class="ticker"><%= o.ticker %></span></td>
          <td class="num"><%= o.quantity.toLocaleString('vi-VN') %></td>
          <td class="num"><%= (o.price / 1000).toFixed(2) %></td>
          <td class="num">₫<%= formatVND(o.total_value) %></td>
          <td><span class="badge badge-<%= o.status %>"><%= o.status === 'pending' ? t.status_pending : o.status === 'approved' ? t.status_approved : t.status_rejected %></span></td>
          <td class="dim small"><%= formatDate(o.created_at) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>

</div>

<script>
// Auto-refresh page during trading hours (prices update in real-time via DNSE)
(function() {
  const dnseConnected = <%= dnseStatus ? dnseStatus.connected : false %>;
  const tradingHours = <%= dnseStatus ? dnseStatus.tradingHours : false %>;
  if (tradingHours) {
    // Refresh page every 30 seconds during trading hours
    setTimeout(function() { location.reload(); }, 30000);
  }
})();
</script>

<%- include('partials/foot') %>
