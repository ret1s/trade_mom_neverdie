<nav>
  <a href="/" class="nav-brand">TRADE MÕM<span class="nav-brand-sub">NEVERDIE</span></a>
  <div class="nav-links">
    <% if (user) { %>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">LỆNH</a>
        <a href="/admin/portfolio" class="<%= currentPath === '/admin/portfolio' ? 'active' : '' %>">PORTFOLIO</a>
      <% } else { %>
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">DANH MỤC</a>
        <a href="/orders/new" class="<%= currentPath === '/orders/new' ? 'active' : '' %>">ĐẶT LỆNH</a>
        <a href="/orders" class="<%= currentPath === '/orders' ? 'active' : '' %>">LỆNH CỦA TÔI</a>
        <a href="/leaderboard" class="<%= currentPath === '/leaderboard' ? 'active' : '' %>">BXH</a>
      <% } %>
      <a href="/logout" class="nav-logout">↩ <%= user.display_name || user.username %></a>
    <% } %>
    <button id="themeToggle" class="theme-toggle" title="Toggle light/dark mode">◐</button>
  </div>
</nav>

<script>
  (function() {
    const root = document.documentElement;
    const btn  = document.getElementById('themeToggle');
    const saved = localStorage.getItem('theme');
    if (saved === 'light') root.classList.add('light');

    btn.addEventListener('click', function() {
      const isLight = root.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    });
  })();
</script>
