<%- include('partials/head', { title: t.page_my_orders }) %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <h1 class="page-title"><%= t.page_my_orders %></h1>
    <a href="/orders/new" class="btn btn-primary"><%= t.btn_new_order %></a>
  </div>

  <div class="card">
    <% if (orders.length === 0) { %>
      <div class="empty-state"><%= t.no_orders %>. <a href="/orders/new"><%= t.no_holdings_link %></a></div>
    <% } else { %>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th><%= t.col_type %></th>
          <th><%= t.col_ticker %></th>
          <th class="num"><%= t.col_qty_short %></th>
          <th class="num"><%= t.col_price %></th>
          <th class="num"><%= t.col_value %></th>
          <th class="num"><%= t.col_fee %></th>
          <th class="num"><%= t.col_net %></th>
          <th><%= t.col_status %></th>
          <th><%= t.col_settlement %></th>
          <th><%= t.col_time %></th>
          <th><%= t.col_admin_note %></th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
        <tr class="<%= o.status === 'rejected' ? 'row-rejected' : '' %>">
          <td class="dim">#<%= o.id %></td>
          <td><span class="badge-type badge-<%= o.order_type %>"><%= o.order_type === 'buy' ? t.type_buy : t.type_sell %></span></td>
          <td><span class="ticker"><%= o.ticker %></span></td>
          <td class="num"><%= o.quantity.toLocaleString('vi-VN') %></td>
          <td class="num"><%= (o.price / 1000).toFixed(2) %></td>
          <td class="num">₫<%= formatVND(o.total_value) %></td>
          <td class="num dim">₫<%= formatVND(o.fee) %></td>
          <td class="num">
            <% if (o.order_type === 'buy') { %>
              <span class="text-sell">₫<%= formatVND(o.total_value + o.fee) %></span>
            <% } else { %>
              <span class="text-buy">₫<%= formatVND(o.total_value - o.fee) %></span>
            <% } %>
          </td>
          <td>
            <span class="badge badge-<%= o.status %>">
              <%= o.status === 'pending' ? t.status_pending : o.status === 'approved' ? t.status_approved : t.status_rejected %>
            </span>
          </td>
          <td class="dim small"><%= o.settlement_date || '—' %></td>
          <td class="dim small"><%= formatDate(o.created_at) %></td>
          <td class="dim small"><%= o.admin_note || '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/foot') %>
