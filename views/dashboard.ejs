<%- include('partials/head', { title: 'Danh mục' }) %>
<%- include('partials/nav') %>

<div class="container">

  <% if (flash.error) { %><div class="alert alert-error"><%= flash.error %></div><% } %>
  <% if (flash.success) { %><div class="alert alert-success"><%= flash.success %></div><% } %>

  <div class="page-header">
    <h1 class="page-title">DANH MỤC</h1>
    <a href="/orders/new" class="btn btn-primary">+ ĐẶT LỆNH MỚI</a>
  </div>

  <!-- Stats -->
  <%
    let marketHoldingsValue = 0;
    let hasMarketPrices = false;
    holdings.forEach(h => {
      if (h.market_price) {
        marketHoldingsValue += h.market_price * h.total_quantity;
        hasMarketPrices = true;
      } else {
        marketHoldingsValue += h.avg_cost * h.total_quantity;
      }
    });
    const unrealizedPnl = hasMarketPrices ? marketHoldingsValue - holdingsValue : null;
    const totalAssets = availableBalance + marketHoldingsValue;
  %>
  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-label">SỐ DƯ KHẢ DỤNG</div>
      <div class="stat-value">₫<%= formatVND(availableBalance) %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">DANH MỤC <%= hasMarketPrices ? '(GIÁ TT)' : '(GIÁ VỐN)' %></div>
      <div class="stat-value">₫<%= formatVND(marketHoldingsValue) %></div>
      <% if (unrealizedPnl !== null) { %>
        <div class="stat-note <%= unrealizedPnl >= 0 ? 'text-buy' : 'text-sell' %>">
          <%= unrealizedPnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(unrealizedPnl)) %> lãi/lỗ chưa TH
        </div>
      <% } %>
    </div>
    <div class="stat-card">
      <div class="stat-label">TỔNG TÀI SẢN</div>
      <div class="stat-value highlight">₫<%= formatVND(totalAssets) %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">P&L vs VỐN BAN ĐẦU</div>
      <% const pnlVsStart = totalAssets - 1000000000; %>
      <div class="stat-value <%= pnlVsStart >= 0 ? 'text-buy' : 'text-sell' %>">
        <%= pnlVsStart >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnlVsStart)) %>
      </div>
      <div class="stat-note <%= pnlVsStart >= 0 ? 'text-buy' : 'text-sell' %>">
        <%= (pnlVsStart / 1000000000 * 100).toFixed(2) %>%
      </div>
    </div>
  </div>

  <!-- Holdings -->
  <div class="card">
    <div class="section-header">
      <div class="section-title">CỔ PHIẾU ĐANG NẮM GIỮ</div>
      <span class="dim"><%= holdings.length %> mã</span>
    </div>
    <% if (holdings.length === 0) { %>
      <div class="empty-state">Chưa có cổ phiếu nào. <a href="/orders/new">Đặt lệnh mua đầu tiên</a></div>
    <% } else { %>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>MÃ</th>
          <th class="num">KL</th>
          <th class="num">KHẢ DỤNG / T+2</th>
          <th class="num">GIÁ VỐN TB</th>
          <th class="num">GIÁ TT</th>
          <th class="num">VỐN ĐẦU TƯ</th>
          <th class="num">GIÁ TRỊ TT</th>
          <th class="num">LÃI/LỖ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% holdings.forEach(h => { %>
        <%
          const marketVal = h.market_price ? h.market_price * h.total_quantity : null;
          const costBasis = h.avg_cost * h.total_quantity;
          const pnl = marketVal !== null ? marketVal - costBasis : null;
          const pnlPct = pnl !== null ? (pnl / costBasis * 100).toFixed(2) : null;
        %>
        <tr>
          <td><span class="ticker"><%= h.ticker %></span></td>
          <td class="num"><%= h.total_quantity.toLocaleString('vi-VN') %></td>
          <td class="num">
            <%= h.available_quantity.toLocaleString('vi-VN') %>
            <% if (h.locked_quantity > 0) { %>
              <div class="tiny-dim locked">⏳ +<%= h.locked_quantity.toLocaleString('vi-VN') %>
                <% if (h.next_settlement) { %>(<%= h.next_settlement %>)<% } %>
              </div>
            <% } %>
          </td>
          <td class="num"><%= (h.avg_cost / 1000).toFixed(2) %> <span class="dim">n</span></td>
          <td class="num">
            <% if (h.market_price) { %>
              <span class="bold <%= pnl >= 0 ? 'text-buy' : 'text-sell' %>"><%= (h.market_price / 1000).toFixed(2) %></span>
              <span class="dim">n</span>
            <% } else { %>
              <span class="dim">—</span>
            <% } %>
          </td>
          <td class="num dim">₫<%= formatVND(costBasis) %></td>
          <td class="num">
            <% if (marketVal !== null) { %>₫<%= formatVND(marketVal) %><% } else { %><span class="dim">—</span><% } %>
          </td>
          <td class="num">
            <% if (pnl !== null) { %>
              <div class="<%= pnl >= 0 ? 'text-buy' : 'text-sell' %>">
                <%= pnl >= 0 ? '+' : '' %>₫<%= formatVND(Math.abs(pnl)) %>
              </div>
              <div class="tiny-dim <%= pnl >= 0 ? 'text-buy' : 'text-sell' %>">
                <%= pnl >= 0 ? '+' : '' %><%= pnlPct %>%
              </div>
            <% } else { %>
              <span class="dim">—</span>
            <% } %>
          </td>
          <td>
            <% if (h.available_quantity > 0) { %>
            <a href="/orders/new?ticker=<%= h.ticker %>&type=sell" class="btn btn-sm btn-sell">BÁN</a>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>

  <!-- Recent Orders -->
  <div class="card">
    <div class="section-header">
      <div class="section-title">LỆNH GẦN ĐÂY</div>
      <a href="/orders" class="dim small-link">Xem tất cả →</a>
    </div>
    <% if (recentOrders.length === 0) { %>
      <div class="empty-state">Chưa có lệnh nào</div>
    <% } else { %>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>LOẠI</th>
          <th>MÃ</th>
          <th class="num">SL</th>
          <th class="num">GIÁ</th>
          <th class="num">GIÁ TRỊ</th>
          <th>TRẠNG THÁI</th>
          <th>THỜI GIAN</th>
        </tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(o => { %>
        <tr>
          <td class="dim">#<%= o.id %></td>
          <td><span class="badge-type badge-<%= o.order_type %>"><%= o.order_type === 'buy' ? 'MUA' : 'BÁN' %></span></td>
          <td><span class="ticker"><%= o.ticker %></span></td>
          <td class="num"><%= o.quantity.toLocaleString('vi-VN') %></td>
          <td class="num"><%= (o.price / 1000).toFixed(2) %> <span class="dim">n</span></td>
          <td class="num">₫<%= formatVND(o.total_value) %></td>
          <td><span class="badge badge-<%= o.status %>"><%= o.status === 'pending' ? '⏳ CHỜ' : o.status === 'approved' ? '✓ DUYỆT' : '✗ TỪ CHỐI' %></span></td>
          <td class="dim small"><%= formatDate(o.created_at) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>

</div>

<%- include('partials/foot') %>
